---
import Base from "../../layouts/Base.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { catMeta } from "../../data/categorias.js";
import { getAllPosts } from "../../lib/posts.js";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  // todas as categorias que realmente existem nos posts (não só as curadas)
  const nomes = [...new Set(posts.flatMap((p) => p.data.categories || []).filter(Boolean))];
  const porSlug = {};
  for (const nome of nomes) {
    const c = catMeta(nome);
    if (!porSlug[c.slug]) porSlug[c.slug] = { cat: c, posts: [] };
    porSlug[c.slug].posts.push(...posts.filter((p) => p.data.categories?.includes(nome)));
  }
  return Object.values(porSlug).map(({ cat, posts: list }) => ({
    params: { categoria: cat.slug },
    props: { cat, posts: [...new Set(list)].sort((a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate)) },
  }));
}

const { cat, posts } = Astro.props;
const SITE = "https://certificacaoiso.com.br";
const schemas = [{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Blog", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: cat.nome, item: `${SITE}/categoria/${cat.slug}/` },
  ],
}];
---

<Base
  title={`${cat.nome} — Certificação ISO`}
  description={`Artigos sobre ${cat.nome}: dicas, guias e boas práticas de certificação ISO pela Templum.`}
  schemas={schemas}
>
  <section class="cat-head section--navy">
    <div class="container lg">
      <nav class="post-bc"><a href="/">Blog</a><span>/</span><span style="color:rgba(255,244,221,.6)">{cat.nome}</span></nav>
      <span class="cat-ico" style={`color:${cat.cor}`}><iconify-icon icon={cat.icon}></iconify-icon></span>
      <h1>{cat.nome}</h1>
      <p>{posts.length} {posts.length === 1 ? "artigo" : "artigos"}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container lg">
      {posts.length ? <div class="blog-grid">{posts.map((p) => <ArticleCard post={p} />)}</div> : <p>Em breve, novos artigos nesta categoria.</p>}
    </div>
  </section>
</Base>

<style>
  .cat-head { padding: 52px 0 44px; }
  .cat-head .post-bc { font-size: 13px; display: flex; gap: 8px; margin-bottom: 18px; }
  .cat-head .post-bc a { color: var(--orange); font-weight: 600; }
  .cat-ico { font-size: 40px; }
  .cat-head h1 { color: var(--cream); font-size: clamp(28px, 4vw, 44px); font-weight: 800; letter-spacing: -0.025em; margin: 10px 0 6px; }
  .cat-head p { color: rgba(255,244,221,0.6); font-size: 15px; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
  @media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
