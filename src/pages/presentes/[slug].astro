---
import Base from "../../layouts/Base.astro";
import { getAllIscas } from "../../lib/posts.js";

// Build estático: uma página por isca ativa (lida do Supabase no build).
export async function getStaticPaths() {
  const iscas = await getAllIscas();
  return iscas.map((isca) => ({ params: { slug: isca.slug }, props: { isca } }));
}

const { isca } = Astro.props;

const SB_URL = import.meta.env.SUPABASE_URL || "https://yfpdrckyuxltvznqfqgh.supabase.co";
const SB_ANON = import.meta.env.SUPABASE_ANON_KEY || "sb_publishable_Yfg9Ts5WRqD4Gc3jeWAS2A_-YWZrtiQ";

const TYPE = {
  planilha: { label: "Planilha gratuita", icon: "solar:chart-square-bold", noun: "material", btn: "Quero a planilha" },
  webinar:  { label: "Webinar gratuito",  icon: "solar:videocamera-record-bold", noun: "webinar", btn: "Quero assistir" },
  checklist:{ label: "Checklist gratuito",icon: "solar:checklist-minimalistic-bold", noun: "checklist", btn: "Quero o checklist" },
  ebook:    { label: "E-book gratuito",   icon: "solar:book-bookmark-bold", noun: "e-book", btn: "Quero o e-book" },
};
const t = TYPE[isca.type] || TYPE.ebook;
const ctaBtn = isca.cta || t.btn;
const download = isca.file_url || "";

const benefits = Array.isArray(isca.benefits) ? isca.benefits : [];
const steps = Array.isArray(isca.steps) ? isca.steps : [];
const ctaItems = Array.isArray(isca.cta_items) ? isca.cta_items : [];
const faq = Array.isArray(isca.faq) ? isca.faq : [];

const metaDesc = isca.subhead || isca.description || `Baixe grátis: ${isca.title}.`;
const schemas = faq.length
  ? [{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    }]
  : [];
---

<Base title={isca.title} description={metaDesc} ogImage={isca.image_url || undefined} schemas={schemas}>
  <!-- HERO + FORM -->
  <section class="isca-hero section--navy" id="form">
    <div class="isca-hero-bg" aria-hidden="true"></div>
    <div class="container lg isca-grid">
      <div class="isca-pitch">
        <span class="tag-pill tag-pill--glow"><iconify-icon icon={t.icon}></iconify-icon> {t.label}</span>
        {isca.headline ? <h1 set:html={isca.headline}></h1> : <h1>{isca.title}</h1>}
        {isca.subhead && <p class="isca-sub">{isca.subhead}</p>}
        {benefits.length > 0 && (
          <ul class="check-list isca-benefits">
            {benefits.map((b) => (
              <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span><span set:html={b}></span></li>
            ))}
          </ul>
        )}
      </div>

      <div class="lead-card isca-card">
        <div class="lead-title">Receba agora — é grátis</div>
        <p class="lead-sub">Preencha os dados e o material abre na hora.</p>
        <form class="form" id="iscaForm" novalidate>
          <div class="field"><label for="i-nome">Nome</label><input class="input" id="i-nome" name="nome" placeholder="Seu nome" required /></div>
          <div class="field"><label for="i-email">E-mail</label><input class="input" id="i-email" type="email" name="email" placeholder="voce@empresa.com" required /></div>
          <div class="form-row">
            <div class="field"><label for="i-tel">WhatsApp</label><input class="input" type="tel" inputmode="numeric" id="i-tel" name="telefone" placeholder="(00) 00000-0000" /></div>
            <div class="field"><label for="i-emp">Empresa</label><input class="input" id="i-emp" name="empresa" placeholder="Sua empresa" /></div>
          </div>
          <button type="submit" class="btn btn--primary btn--block btn--lg">{ctaBtn} <iconify-icon icon="solar:download-minimalistic-bold"></iconify-icon></button>
          <p class="isca-legal">Ao enviar, você concorda em receber contato da Templum. Seus dados são protegidos conforme a LGPD.</p>
        </form>
        <div class="form-success" id="iscaSuccess" hidden>
          <iconify-icon icon="solar:check-circle-bold"></iconify-icon>
          <div><h4>Material liberado!</h4><p>Se o download não abrir, clique no botão abaixo.</p><a id="iscaDl" class="btn btn--primary btn--sm" href={download || "#"} target="_blank" rel="noopener" style="margin-top:12px">Abrir material</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- DENTRO DO MATERIAL -->
  {steps.length > 0 && (
    <section class="section section--cream">
      <div class="container xl">
        <div class="section-header">
          <span class="tag-pill">O que você vai encontrar</span>
          <h2>Dentro do <em class="accent">{t.noun}</em></h2>
        </div>
        <div class="step-grid">
          {steps.map((s) => (
            <div class="step-card"><span class="step-num">{s.num}</span><h3>{s.title}</h3><p>{s.text}</p></div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA INTERMEDIÁRIO -->
  {isca.cta_title && (
    <section class="section">
      <div class="container md isca-mid">
        <h2 set:html={isca.cta_title}></h2>
        {isca.cta_copy && <p>{isca.cta_copy}</p>}
        {ctaItems.length > 0 && (
          <ul class="check-list isca-mid-list">
            {ctaItems.map((c) => <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>{c}</li>)}
          </ul>
        )}
        <a href="#form" class="btn btn--primary btn--lg">{ctaBtn} <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faq.length > 0 && (
    <section class="section section--cream">
      <div class="container md">
        <div class="section-header"><span class="tag-pill">Dúvidas</span><h2>Perguntas <em class="accent">frequentes</em></h2></div>
        <div class="faq-list">
          {faq.map((f) => (
            <details class="faq-item"><summary>{f.q}<iconify-icon icon="solar:add-circle-linear"></iconify-icon></summary><div class="faq-a">{f.a}</div></details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA FINAL -->
  <section class="cta-band">
    <div class="container md">
      <h2>Quer ir <em>além do material</em>?</h2>
      <p>Fale com um especialista e descubra como a Templum leva a sua empresa até a certificação — com garantia de 200%.</p>
      <a href="https://templum.com.br/form" class="btn btn--dark btn--lg">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .isca-hero { position: relative; overflow: hidden; padding: clamp(48px,7vh,90px) 0; }
  .isca-hero-bg { position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(720px 460px at 14% 0%, rgba(255,89,37,0.20), transparent 60%),
                radial-gradient(560px 380px at 100% 100%, rgba(20,167,175,0.10), transparent 60%); }
  .isca-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(32px,5vw,60px); align-items: start; }
  @media (max-width: 920px) { .isca-grid { grid-template-columns: 1fr; } }
  .isca-pitch .tag-pill { margin-bottom: 20px; }
  .isca-pitch h1 { font-size: clamp(30px,4vw,50px); font-weight: 800; line-height: 1.08; letter-spacing: -0.03em; color: var(--cream); }
  .isca-pitch h1 :global(em) { font-style: normal; color: var(--orange); }
  .isca-sub { font-size: 16.5px; line-height: 1.65; color: rgba(255,244,221,0.82); margin: 18px 0 24px; max-width: 520px; }
  .isca-benefits { gap: 14px; }
  .isca-benefits .check-item { color: var(--cream); }
  .isca-benefits :global(strong) { color: var(--cream); font-weight: 800; }

  .isca-card { width: 100%; min-width: 0; box-sizing: border-box; position: sticky; top: 96px; }
  @media (max-width: 920px) { .isca-card { position: static; } }
  .isca-legal { font-size: 11.5px; color: var(--text-soft); line-height: 1.5; margin-top: 4px; }
  .form[hidden], .form-success[hidden] { display: none; }

  .isca-mid { text-align: center; }
  .isca-mid h2 { font-size: clamp(26px,3.4vw,40px); font-weight: 800; letter-spacing: -0.025em; }
  .isca-mid h2 :global(em) { font-style: italic; color: var(--orange); }
  .isca-mid p { font-size: 16.5px; color: var(--text-mid); line-height: 1.6; margin: 14px auto 0; max-width: 560px; }
  .isca-mid-list { display: inline-flex; flex-direction: column; gap: 10px; text-align: left; margin: 22px 0; }
</style>

<script is:inline define:vars={{ SB_URL, SB_ANON, iscaId: isca.id, slug: isca.slug, download }}>
  (function () {
    var form = document.getElementById("iscaForm");
    if (!form) return;
    var success = document.getElementById("iscaSuccess");
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      var d = {}; new FormData(form).forEach(function (v, k) { d[k] = v; });
      if (window.trk && typeof window.trk.lead === "function") {
        try { window.trk.lead({ email: d.email, phone: d.telefone, name: d.nome }); } catch (_) {}
      }
      try {
        fetch(SB_URL + "/rest/v1/blog_templum_leads", {
          method: "POST",
          headers: { "Content-Type": "application/json", apikey: SB_ANON, Authorization: "Bearer " + SB_ANON, Prefer: "return=minimal" },
          keepalive: true,
          body: JSON.stringify({ name: d.nome || "", email: d.email || "", phone: d.telefone || "", company: d.empresa || "", source: "presente", page: "/presentes/" + slug + "/", isca_id: iscaId }),
        });
      } catch (_) {}
      form.hidden = true; if (success) success.hidden = false;
      if (download) window.open(download, "_blank", "noopener");
    });
  })();
</script>
