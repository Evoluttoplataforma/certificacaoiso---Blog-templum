---
import Base from "../layouts/Base.astro";
---
<Base title="Buscar artigos | Certificação ISO" description="Busque artigos sobre certificação e normas ISO." robots="noindex,follow">
  <section class="busca section--navy">
    <div class="container md">
      <h1>Buscar artigos</h1>
      <form class="busca-box" onsubmit="return false">
        <iconify-icon icon="solar:magnifer-linear"></iconify-icon>
        <input type="search" id="q" placeholder="Digite uma norma, tema ou pergunta…" autocomplete="off" autofocus />
      </form>
      <p class="busca-hint" id="hint">Carregando artigos…</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container md"><div class="blog-grid" id="results"></div></div>
  </section>
</Base>
<script is:inline>
  (function () {
    var input = document.getElementById("q"), results = document.getElementById("results"), hint = document.getElementById("hint");
    var data = [];
    function norm(s) { return (s || "").toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, ""); }
    function card(p) {
      var thumb = p.img ? '<img src="' + p.img + '" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover">' : '<span class="ac-thumb-fb"><iconify-icon icon="solar:document-text-bold"></iconify-icon></span>';
      return '<article class="ac"><a href="/' + p.s + '/" class="ac-thumb" aria-label="' + (p.t||"").replace(/"/g,"&quot;") + '">' + thumb + '</a><div class="ac-body">' +
        (p.c ? '<span class="ac-cat">' + p.c + '</span>' : '') +
        '<h2 class="ac-title"><a href="/' + p.s + '/">' + p.t + '</a></h2>' +
        '<p class="ac-desc">' + p.d + '</p></div></article>';
    }
    function render(list) {
      results.innerHTML = list.slice(0, 60).map(card).join("");
      hint.textContent = input.value.trim() ? (list.length + " resultado(s)") : (data.length + " artigos no blog");
    }
    function search() {
      var q = norm(input.value.trim());
      if (!q) { render(data.slice(0, 12)); return; }
      var terms = q.split(/\s+/);
      var hits = data.filter(function (p) { var hay = norm(p.t + " " + p.c + " " + p.d); return terms.every(function (t) { return hay.indexOf(t) >= 0; }); });
      render(hits);
    }
    fetch("/search-index.json").then(function (r) { return r.json(); }).then(function (j) {
      data = j;
      var u = new URLSearchParams(location.search).get("q"); if (u) input.value = u;
      search();
    });
    input.addEventListener("input", search);
  })();
</script>
<style>
  .busca { padding: 48px 0 36px; }
  .busca h1 { color: var(--cream); font-size: clamp(26px, 3.5vw, 40px); font-weight: 800; letter-spacing: -0.025em; margin-bottom: 20px; }
  .busca-box { display: flex; align-items: center; gap: 12px; background: var(--surface); border-radius: 999px; padding: 6px 22px; box-shadow: var(--shadow-lift); }
  .busca-box iconify-icon { font-size: 22px; color: var(--text-soft); }
  .busca-box input { flex: 1; border: 0; outline: 0; font-size: 17px; font-family: inherit; padding: 14px 0; background: none; color: var(--text); }
  .busca-hint { color: rgba(255,244,221,0.6); font-size: 14px; margin-top: 14px; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
