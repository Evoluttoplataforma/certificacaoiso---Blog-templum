---
import Base from "../layouts/Base.astro";
import Sidebar from "../components/Sidebar.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { catMeta } from "../data/categorias.js";
import { getAllPosts, tldrOf, getIscaForCategories } from "../lib/posts.js";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post, posts } }));
}

const { post, posts } = Astro.props;
const d = post.data;
const SITE = "https://certificacaoiso.com.br";
const url = `${SITE}/${post.slug}/`;
const cat = (d.categories && d.categories[0]) || "";
const catSlug = cat ? catMeta(cat).slug : "";
const dataFmt = new Date(d.pubDate).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" });

// SEO/AIEO/GEO por artigo
// título: usa seo_title; senão anexa a marca só se couber em ~60 chars (evita "title too long")
const _full = `${d.title} | Certificação ISO`;
const seoTitle = d.seoTitle || (_full.length <= 60 ? _full : d.title);
const tldr = (d.tldr || tldrOf(post)).trim();
const seoDesc = (d.seoDescription || d.description || tldr).slice(0, 160);
const keywords = (d.keywords && d.keywords.length ? d.keywords : d.categories) || [];
// wordCount a partir do HTML (sinal de profundidade p/ SEO/GEO)
const wordCount = post.content ? post.content.replace(/<[^>]+>/g, " ").split(/\s+/).filter(Boolean).length : 0;
const faq = d.faq || [];

// relacionados (mesma categoria) — seleção CÍCLICA p/ distribuir links internos:
// cada post linka os 3 seguintes da sua categoria → todo post recebe links (não só o da categoria).
const catList = posts.filter((p) => p.data.categories?.some((c) => d.categories?.includes(c)));
const selfPos = catList.findIndex((p) => p.slug === post.slug);
const related = [];
for (let i = 1; i <= 3 && i < catList.length; i++) related.push(catList[(selfPos + i) % catList.length]);
const recent = posts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate))
  .slice(0, 4);
// isca do segmento do artigo (definida no CMS por norma; cai no default)
const isca = await getIscaForCategories(d.categories);

// --- JSON-LD: BlogPosting + BreadcrumbList ---
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: d.title,
    description: d.description,
    image: d.heroImage ? [new URL(d.heroImage, SITE).href] : undefined,
    datePublished: new Date(d.pubDate).toISOString(),
    dateModified: new Date(d.updatedDate || d.pubDate).toISOString(),
    author: { "@type": "Person", name: d.author },
    publisher: { "@id": `${SITE}/#organization` },
    mainEntityOfPage: url,
    inLanguage: "pt-BR",
    articleSection: cat || undefined,
    abstract: tldr || undefined,
    wordCount: wordCount || undefined,
    keywords: keywords.length ? keywords : undefined,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Blog", item: `${SITE}/` },
      cat ? { "@type": "ListItem", position: 2, name: cat, item: `${SITE}/categoria/${catSlug}/` } : null,
      { "@type": "ListItem", position: cat ? 3 : 2, name: d.title, item: url },
    ].filter(Boolean),
  },
];

// FAQPage só quando o artigo tem perguntas (preenchido no CMS) → "sanfoninhas" no Google.
if (faq.length) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.pergunta,
      acceptedAnswer: { "@type": "Answer", text: f.resposta },
    })),
  });
}
---

<Base
  title={seoTitle}
  description={seoDesc}
  ogImage={d.ogImage || d.heroImage || "/assets/og/certificacaoiso-og.jpg"}
  ogType="article"
  schemas={schemas}
>
  <article class="post">
    <div class="container md post-head">
      <nav class="post-bc">
        <a href="/">Blog</a>
        {cat && <><span>/</span><a href={`/categoria/${catSlug}/`}>{cat}</a></>}
      </nav>
      <h1 class="post-title">{d.title}</h1>
      <div class="post-meta">
        <span class="post-author"><iconify-icon icon="solar:user-circle-bold"></iconify-icon> {d.author}</span>
        <time datetime={new Date(d.pubDate).toISOString()}>{dataFmt}</time>
      </div>
    </div>

    {d.heroImage && (
      <div class="container lg"><div class="post-hero"><img src={d.heroImage} alt={d.title} /></div></div>
    )}

    <div class="container lg post-grid">
      <div class="post-content">
        {tldr && (
          <div class="post-tldr">
            <span class="post-tldr-label"><iconify-icon icon="solar:bolt-bold"></iconify-icon> Resposta rápida</span>
            <p>{tldr}</p>
          </div>
        )}
        <Fragment set:html={post.content} />

        {faq.length > 0 && (
          <section class="post-faq">
            <h2>Perguntas frequentes</h2>
            {faq.map((f) => (
              <details class="post-faq-item">
                <summary>{f.pergunta}</summary>
                <p>{f.resposta}</p>
              </details>
            ))}
          </section>
        )}

        <!-- CTA no fim do artigo -->
        <div class="post-cta">
          <div>
            <h3>Pronto para certificar sua empresa?</h3>
            <p>Fale com um especialista da Templum e receba um diagnóstico gratuito — com garantia de 200%.</p>
          </div>
          <a href={`https://templum.com.br/form?utm_source=blog&utm_medium=cta-artigo&utm_campaign=${post.slug}`} class="btn btn--primary btn--lg" data-trk-event="cta-artigo">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
        </div>
      </div>
      <Sidebar ref={post.slug} author={d.author} recent={recent} isca={isca} />
    </div>

    <!-- Comentários (client-side: lê aprovados, envia como pendente) -->
    <section class="container md post-comments">
      <h2>Comentários</h2>
      <div id="cmt-list" class="cmt-list"><p class="cmt-empty">Carregando…</p></div>
      <form id="cmt-form" class="cmt-form">
        <h3>Deixe seu comentário</h3>
        <div class="cmt-row">
          <input name="nome" placeholder="Seu nome" required />
          <input name="email" type="email" placeholder="Seu e-mail (não publicado)" />
        </div>
        <textarea name="content" rows="4" placeholder="Escreva seu comentário…" required></textarea>
        <div class="cmt-actions">
          <button type="submit" class="btn btn--primary">Enviar comentário</button>
          <span id="cmt-msg" class="cmt-msg"></span>
        </div>
        <p class="cmt-note">Seu comentário passa por moderação antes de aparecer.</p>
      </form>
    </section>
    <script define:vars={{ postId: post.id, SB_URL: "https://yfpdrckyuxltvznqfqgh.supabase.co", SB_ANON: "sb_publishable_Yfg9Ts5WRqD4Gc3jeWAS2A_-YWZrtiQ" }}>
      (function () {
        var H = { apikey: SB_ANON, Authorization: "Bearer " + SB_ANON };
        var list = document.getElementById("cmt-list");
        var esc = function (s) { return (s || "").replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); };
        var fmt = function (d) { return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" }); };
        function load() {
          fetch(SB_URL + "/rest/v1/blog_templum_comments?post_id=eq." + postId + "&status=eq.approved&select=author_name,content,created_at&order=created_at.desc", { headers: H })
            .then(function (r) { return r.json(); })
            .then(function (c) {
              if (!c || !c.length) { list.innerHTML = '<p class="cmt-empty">Seja o primeiro a comentar.</p>'; return; }
              list.innerHTML = c.map(function (x) { return '<div class="cmt"><div class="cmt-h"><strong>' + esc(x.author_name) + '</strong><time>' + fmt(x.created_at) + '</time></div><p>' + esc(x.content) + '</p></div>'; }).join("");
            }).catch(function () { list.innerHTML = ""; });
        }
        load();
        var f = document.getElementById("cmt-form"), msg = document.getElementById("cmt-msg");
        f.addEventListener("submit", function (e) {
          e.preventDefault(); msg.textContent = "Enviando…";
          var body = { post_id: postId, author_name: f.nome.value, author_email: f.email.value || null, content: f.content.value, status: "pending" };
          fetch(SB_URL + "/rest/v1/blog_templum_comments", { method: "POST", headers: Object.assign({}, H, { "Content-Type": "application/json", Prefer: "return=minimal" }), body: JSON.stringify(body) })
            .then(function (r) { if (r.ok) { msg.textContent = "Enviado! Aparece após aprovação. ✓"; f.reset(); } else { r.text().then(function (t) { msg.textContent = "Erro: " + t.slice(0, 100); }); } })
            .catch(function () { msg.textContent = "Erro ao enviar."; });
        });
      })();
    </script>

    {related.length > 0 && (
      <section class="section section--cream">
        <div class="container lg">
          <div class="section-header"><span class="tag-pill">Continue lendo</span><h2>Artigos <em class="accent">relacionados</em></h2></div>
          <div class="post-related">{related.map((p) => <ArticleCard post={p} />)}</div>
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  /* Comentários */
  .post-comments { padding-bottom: 64px; }
  .post-comments > h2 { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 20px; }
  .cmt-list { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }
  .cmt { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-16); padding: 16px 18px; }
  .cmt-h { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .cmt-h strong { font-size: 14.5px; color: var(--text); }
  .cmt-h time { font-size: 12px; color: var(--text-soft); }
  .cmt p { font-size: 15px; color: var(--text-2); line-height: 1.6; }
  .cmt-empty { color: var(--text-soft); font-size: 14px; }
  .cmt-form { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r-20); padding: 24px; }
  .cmt-form h3 { font-size: 18px; font-weight: 800; margin-bottom: 14px; }
  .cmt-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  @media (max-width: 600px) { .cmt-row { grid-template-columns: 1fr; } }
  .cmt-form input, .cmt-form textarea { width: 100%; padding: 11px 14px; border: 1px solid var(--border-2); border-radius: var(--r-12); font-family: inherit; font-size: 15px; background: var(--surface); }
  .cmt-form input:focus, .cmt-form textarea:focus { outline: none; border-color: var(--orange); }
  .cmt-form textarea { margin-bottom: 14px; resize: vertical; }
  .cmt-actions { display: flex; align-items: center; gap: 14px; }
  .cmt-msg { font-size: 13px; color: var(--text-mid); }
  .cmt-note { font-size: 12.5px; color: var(--text-soft); margin-top: 10px; }

  .post-head { padding-top: 40px; }
  .post-bc { font-size: 13px; color: var(--text-soft); display: flex; gap: 8px; margin-bottom: 16px; }
  .post-bc a { color: var(--orange-ink); font-weight: 600; }
  .post-title { font-size: clamp(28px, 4vw, 44px); font-weight: 800; line-height: 1.12; letter-spacing: -0.025em; }
  .post-meta { display: flex; align-items: center; gap: 16px; margin-top: 16px; font-size: 14px; color: var(--text-mid); }
  .post-author { display: inline-flex; align-items: center; gap: 6px; font-weight: 600; color: var(--text-2); }
  .post-author iconify-icon { color: var(--orange); font-size: 18px; }
  .post-hero { margin: 28px 0 8px; border-radius: var(--r-24); overflow: hidden; aspect-ratio: 16/8; }
  .post-hero img { width: 100%; height: 100%; object-fit: cover; }
  /* items-start + <aside> sticky (padrão do blog Evolutto). O aside gruda dentro
     do grid, que é tão alto quanto o artigo → "trilho" pro sticky. */
  .post-grid { display: grid; grid-template-columns: minmax(0,1fr) 340px; gap: 48px; align-items: start; padding-top: 32px; padding-bottom: 64px; }
  @media (max-width: 980px) { .post-grid { grid-template-columns: 1fr; } }
  /* tipografia do conteúdo do artigo */
  .post-content { font-size: 17px; line-height: 1.75; color: var(--text-2); min-width: 0; }
  .post-content :global(h2) { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin: 38px 0 14px; line-height: 1.2; }
  .post-content :global(h3) { font-size: 21px; font-weight: 800; margin: 30px 0 12px; }
  .post-content :global(p) { margin: 0 0 18px; }
  .post-content :global(a:not(.btn)) { color: var(--orange-ink); text-decoration: underline; text-underline-offset: 2px; }
  .post-content :global(img) { max-width: 100%; height: auto; border-radius: var(--r-16); margin: 22px 0; }
  .post-content :global(ul), .post-content :global(ol) { margin: 0 0 18px 22px; display: flex; flex-direction: column; gap: 8px; }
  .post-content :global(blockquote) { border-left: 4px solid var(--orange); padding: 6px 0 6px 20px; margin: 24px 0; font-style: italic; color: var(--text-mid); }
  .post-content :global(figure) { margin: 22px 0; }
  .post-content :global(iframe) { max-width: 100%; border-radius: var(--r-16); aspect-ratio: 16/9; width: 100%; }
  .post-content :global(table) { width: 100%; border-collapse: collapse; margin: 22px 0; font-size: 15px; }
  .post-content :global(th), .post-content :global(td) { border: 1px solid var(--border); padding: 10px 12px; text-align: left; }
  /* TL;DR / Resposta rápida — citável por IA, answer-first */
  .post-tldr { background: color-mix(in srgb, var(--orange) 7%, var(--surface)); border: 1px solid color-mix(in srgb, var(--orange) 28%, transparent); border-left: 4px solid var(--orange); border-radius: var(--r-16); padding: 18px 22px; margin: 0 0 30px; }
  .post-tldr-label { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--orange-ink); margin-bottom: 6px; }
  .post-tldr p { font-size: 16px; line-height: 1.6; color: var(--text); margin: 0; font-weight: 500; }
  /* FAQ — vira FAQPage no JSON-LD (sanfoninhas no Google) */
  .post-faq { margin-top: 44px; }
  .post-faq > h2 { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 16px; }
  .post-faq-item { border: 1px solid var(--border); border-radius: var(--r-12); padding: 4px 18px; margin-bottom: 10px; background: var(--surface); }
  .post-faq-item summary { font-size: 16px; font-weight: 700; color: var(--text); cursor: pointer; padding: 14px 0; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .post-faq-item summary::after { content: "+"; font-size: 22px; color: var(--orange-ink); font-weight: 700; }
  .post-faq-item[open] summary::after { content: "−"; }
  .post-faq-item p { margin: 0 0 14px; font-size: 15.5px; line-height: 1.65; color: var(--text-mid); }
  .post-cta { margin-top: 44px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--r-24); padding: 30px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .post-cta h3 { font-size: 20px; font-weight: 800; margin-bottom: 6px; }
  .post-cta p { font-size: 14.5px; color: var(--text-mid); max-width: 460px; }
  .post-related { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 860px) { .post-related { grid-template-columns: 1fr; } }
</style>
